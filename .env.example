# ──────────────────────────────────────────────────────────────────────────────
# Langafy — Root Environment Variables
# Copy this file to .env and fill in real values for local development.
# This file is consumed by docker-compose (docker/docker-compose.yml).
#
# ASP.NET Core env var naming: double underscores (__) map to colons (:) in
# appsettings.json keys. e.g. Firebase__ProjectId → Firebase:ProjectId
# ──────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL (used by docker-compose to configure the db service) ───────────
POSTGRES_USER=langafy
POSTGRES_PASSWORD=langafy_dev
POSTGRES_DB=langafy

# ── API — Firebase Authentication ────────────────────────────────────────────
# docker-compose maps this to Firebase__ProjectId inside the API container
FIREBASE_PROJECT_ID=your-firebase-project-id

# ── API — OpenRouter (AI conversations) ──────────────────────────────────────
# docker-compose maps this to OpenRouter__ApiKey inside the API container
OPENROUTER_API_KEY=your-openrouter-api-key

# ── API — CORS (production only) ─────────────────────────────────────────────
# docker-compose maps this to AllowedOrigin inside the API container
ALLOWED_ORIGIN=https://langafy.example.com

# ── Web app (Next.js NEXT_PUBLIC_* vars) ─────────────────────────────────────
# These are baked into the Next.js build at compile time.
# See apps/web/.env.example for the full list.
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# ── Mobile app (Expo EXPO_PUBLIC_* vars) ─────────────────────────────────────
# Expo reads EXPO_PUBLIC_* vars and app.config.ts injects them into
# Constants.expoConfig.extra. See apps/mobile/.env.example for the full list.
EXPO_PUBLIC_API_URL=http://localhost:5000
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-app-id
