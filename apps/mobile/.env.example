# ──────────────────────────────────────────────────────────────────────────────
# Langafy Mobile App — Environment Variables
# Copy this file to .env.local for local development.
#
# Expo reads EXPO_PUBLIC_* vars at build/start time. app.config.ts injects them
# into Constants.expoConfig.extra so they are accessible at runtime via:
#   Constants.expoConfig?.extra?.apiUrl
#
# All EXPO_PUBLIC_* vars are bundled into the app — never put secrets here.
# ──────────────────────────────────────────────────────────────────────────────

# API base URL
EXPO_PUBLIC_API_URL=http://localhost:5000

# Firebase Authentication (public keys — safe to expose in client bundles)
EXPO_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
EXPO_PUBLIC_FIREBASE_APP_ID=your-firebase-app-id
