{
  "name": "langafy",
  "version": "0.1.1",
  "description": "A language learning platform with CEFR-aligned lessons, conversational AI practice, and mini-games",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm -w web run dev",
    "dev:mobile": "npm -w mobile run dev",
    "dev:api": "cd apps/api/LangafyApi && dotnet run",
    "seed": "node scripts/seed.js",
    "seed:reset": "node scripts/seed.js --reset",
    "seed:help": "node scripts/seed.js --help",
    "lint": "npm -w web run lint && npm -w mobile run lint && dotnet format apps/api/LangafyApi/LangafyApi.csproj --verify-no-changes",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,md,css}\"",
    "docker:up": "docker compose -f docker/docker-compose.yml --env-file .env up",
    "docker:rebuild": "docker compose -f docker/docker-compose.yml --env-file .env build --no-cache && docker compose -f docker/docker-compose.yml --env-file .env up",
    "docker:down": "docker compose -f docker/docker-compose.yml --env-file .env down -v",
    "test:web": "npm -w web run test",
    "test:mobile": "npm -w mobile run test",
    "test:api": "dotnet test apps/api/LangafyApi.Tests/LangafyApi.Tests.csproj",
    "test:shared": "npm -w @langafy/shared-game-logic run test",
    "test:all": "npm run test:shared && npm run test:web && npm run test:mobile && npm run test:api",
    "test:regression": "npm -w web run test:regression",
    "bump:patch": "node scripts/bump.js patch",
    "bump:minor": "node scripts/bump.js minor",
    "bump:major": "node scripts/bump.js major",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "apps/web/**/*.{ts,tsx}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,js,jsx,mjs,json,md,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  }
}
