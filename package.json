{
  "name": "langafy",
  "version": "0.1.0",
  "description": "A language learning platform with CEFR-aligned lessons, conversational AI practice, and mini-games",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/mobile",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm -w web run dev",
    "dev:mobile": "npm -w mobile run dev",
    "dev:api": "cd apps/api/LangafyApi && dotnet run",
    "seed": "node scripts/seed.js",
    "seed:reset": "node scripts/seed.js --reset",
    "seed:help": "node scripts/seed.js --help",
    "lint": "npm -w web run lint && npm -w mobile run lint && dotnet format apps/api/LangafyApi/LangafyApi.csproj --verify-no-changes",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,mjs,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,mjs,json,md,css}\"",
    "docker:up": "docker compose -f docker/docker-compose.yml --env-file .env up",
    "docker:rebuild": "docker compose -f docker/docker-compose.yml --env-file .env up --build",
    "docker:down": "docker compose -f docker/docker-compose.yml --env-file .env down"
  }
}
